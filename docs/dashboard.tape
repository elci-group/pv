# pv dashboard, intent recognition, and plain-language explain
Output docs/dashboard.gif

Set Shell bash
Set FontSize 15
Set FontFamily "DejaVu Sans Mono"
Set Width 1200
Set Height 880
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set Framerate 30

Hide
Type "export PS1='$ '"
Enter
Type "clear"
Enter
Show

Type "pv"
Sleep 400ms
Enter
Sleep 2500ms

Type "pv intent cargo build --release"
Sleep 400ms
Enter
Sleep 1800ms

Type "pv explain"
Sleep 400ms
Enter
Sleep 3000ms
