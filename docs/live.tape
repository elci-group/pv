# pv live — realtime pressure view with trend arrows
Output docs/live.gif

Set Shell bash
Set FontSize 15
Set FontFamily "DejaVu Sans Mono"
Set Width 980
Set Height 580
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set Framerate 30

Hide
Type "export PS1='$ '"
Enter
Type "clear"
Enter
Show

Type "pv live --no-infer"
Sleep 400ms
Enter
Sleep 9000ms

Type "q"
Sleep 800ms
